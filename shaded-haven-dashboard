<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Shaded Haven RV Park — Google Ads Dashboard</title>
  <link href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@400;500&family=DM+Serif+Display&display=swap" rel="stylesheet" />
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    :root {
      --bg-primary: #ffffff;
      --bg-secondary: #f5f4f0;
      --bg-tertiary: #eeede9;
      --text-primary: #1a1a18;
      --text-secondary: #6b6a65;
      --border: rgba(0,0,0,0.1);
      --border-md: rgba(0,0,0,0.15);
      --radius-md: 8px;
      --radius-lg: 12px;
    }

    @media (prefers-color-scheme: dark) {
      :root {
        --bg-primary: #1e1e1c;
        --bg-secondary: #2a2a28;
        --bg-tertiary: #141412;
        --text-primary: #f0efeb;
        --text-secondary: #9a9993;
        --border: rgba(255,255,255,0.1);
        --border-md: rgba(255,255,255,0.15);
      }
    }

    body {
      font-family: 'DM Sans', sans-serif;
      background: var(--bg-tertiary);
      color: var(--text-primary);
      min-height: 100vh;
      padding: 2rem 1rem;
    }

    .dash {
      max-width: 1100px;
      margin: 0 auto;
      background: var(--bg-primary);
      border-radius: 16px;
      padding: 2rem;
      border: 0.5px solid var(--border);
    }

    .header {
      display: flex;
      align-items: flex-start;
      justify-content: space-between;
      flex-wrap: wrap;
      gap: 12px;
      margin-bottom: 1.5rem;
      padding-bottom: 1rem;
      border-bottom: 0.5px solid var(--border);
    }

    .header h1 {
      font-family: 'DM Serif Display', serif;
      font-size: 26px;
      font-weight: 400;
      color: var(--text-primary);
      line-height: 1.2;
    }

    .header p {
      font-size: 13px;
      color: var(--text-secondary);
      margin-top: 4px;
    }

    .badges { display: flex; gap: 8px; flex-wrap: wrap; justify-content: flex-end; }

    .badge {
      font-size: 11px;
      padding: 4px 12px;
      border-radius: 20px;
      font-weight: 500;
      white-space: nowrap;
    }
    .badge-green { background: #EAF3DE; color: #3B6D11; }
    .badge-blue  { background: #E6F1FB; color: #185FA5; }

    .kpi-grid {
      display: grid;
      grid-template-columns: repeat(4, minmax(0, 1fr));
      gap: 12px;
      margin-bottom: 1.25rem;
    }

    @media (max-width: 600px) {
      .kpi-grid { grid-template-columns: repeat(2, 1fr); }
      .charts-top, .charts-bot { grid-template-columns: 1fr !important; }
      .insight-grid { grid-template-columns: 1fr !important; }
      .action-items { grid-template-columns: 1fr !important; }
    }

    .kpi {
      background: var(--bg-secondary);
      border-radius: var(--radius-md);
      padding: 14px 16px;
    }

    .kpi-label {
      font-size: 11px;
      color: var(--text-secondary);
      text-transform: uppercase;
      letter-spacing: .05em;
      margin-bottom: 6px;
    }

    .kpi-value {
      font-size: 28px;
      font-weight: 500;
      color: var(--text-primary);
      line-height: 1;
    }

    .kpi-sub { font-size: 11px; color: var(--text-secondary); margin-top: 5px; }
    .kpi-good { color: #3B6D11; font-weight: 500; }
    .kpi-info { color: #185FA5; font-weight: 500; }

    .charts-top { display: grid; grid-template-columns: 1fr 1.4fr; gap: 12px; margin-bottom: 12px; }
    .charts-bot { display: grid; grid-template-columns: 1.3fr 1fr; gap: 12px; margin-bottom: 12px; }

    .card {
      background: var(--bg-primary);
      border: 0.5px solid var(--border);
      border-radius: var(--radius-lg);
      padding: 16px;
    }

    .card-title {
      font-size: 11px;
      font-weight: 500;
      color: var(--text-secondary);
      text-transform: uppercase;
      letter-spacing: .06em;
      margin-bottom: 12px;
    }

    .legend-row {
      display: flex;
      flex-wrap: wrap;
      gap: 10px;
      margin-top: 10px;
      font-size: 11px;
      color: var(--text-secondary);
    }

    .legend-dot {
      width: 10px;
      height: 10px;
      border-radius: 2px;
      display: inline-block;
      margin-right: 4px;
      vertical-align: middle;
    }

    .insight-grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 10px;
      margin-bottom: 12px;
    }

    .insight {
      background: var(--bg-secondary);
      border-radius: var(--radius-md);
      padding: 14px 16px;
    }

    .insight-text {
      font-size: 12px;
      color: var(--text-secondary);
      line-height: 1.6;
    }

    .insight-text strong {
      font-weight: 500;
      color: var(--text-primary);
    }

    .action-box {
      background: #E6F1FB;
      border: 0.5px solid #B5D4F4;
      border-radius: var(--radius-lg);
      padding: 16px 18px;
    }

    .action-title {
      font-size: 11px;
      font-weight: 500;
      color: #0C447C;
      text-transform: uppercase;
      letter-spacing: .06em;
      margin-bottom: 10px;
    }

    .action-items {
      display: grid;
      grid-template-columns: 1fr 1fr 1fr;
      gap: 8px;
    }

    .action-item {
      background: #fff;
      border: 0.5px solid #B5D4F4;
      border-radius: var(--radius-md);
      padding: 10px 12px;
      font-size: 12px;
      color: #185FA5;
      line-height: 1.5;
    }

    .action-item strong {
      display: block;
      font-weight: 500;
      font-size: 10px;
      text-transform: uppercase;
      letter-spacing: .04em;
      margin-bottom: 4px;
      color: #0C447C;
    }

    footer {
      text-align: center;
      margin-top: 2rem;
      font-size: 11px;
      color: var(--text-secondary);
    }
  </style>
</head>
<body>
  <div class="dash">
    <div class="header">
      <div>
        <h1>Shaded Haven RV Park</h1>
        <p>Google Ads Performance Dashboard &nbsp;·&nbsp; March 4 – April 2, 2025</p>
      </div>
      <div class="badges">
        <span class="badge badge-green">Phrase Match Active</span>
        <span class="badge badge-blue">Conversion Tracking On</span>
      </div>
    </div>

    <div class="kpi-grid">
      <div class="kpi">
        <div class="kpi-label">Max CPC set</div>
        <div class="kpi-value">$3.00</div>
        <div class="kpi-sub">Bid ceiling</div>
      </div>
      <div class="kpi">
        <div class="kpi-label">Actual Avg CPC</div>
        <div class="kpi-value">$2.24</div>
        <div class="kpi-sub"><span class="kpi-good">25% below max</span> — healthy</div>
      </div>
      <div class="kpi">
        <div class="kpi-label">Mobile share</div>
        <div class="kpi-value">91.7%</div>
        <div class="kpi-sub">Click-to-Call priority</div>
      </div>
      <div class="kpi">
        <div class="kpi-label">Peak hours</div>
        <div class="kpi-value">11–4</div>
        <div class="kpi-sub"><span class="kpi-info">Aggressive bid window</span></div>
      </div>
    </div>

    <div class="charts-top">
      <div class="card">
        <div class="card-title">Budget spend by device</div>
        <div style="position:relative;width:100%;height:190px"><canvas id="deviceChart"></canvas></div>
        <div class="legend-row" id="deviceLegend"></div>
      </div>
      <div class="card">
        <div class="card-title">Customer age profile — audience reach</div>
        <div style="position:relative;width:100%;height:210px"><canvas id="ageChart"></canvas></div>
      </div>
    </div>

    <div class="charts-bot">
      <div class="card">
        <div class="card-title">Peak search hours</div>
        <div style="position:relative;width:100%;height:210px"><canvas id="hourChart"></canvas></div>
      </div>
      <div class="card">
        <div class="card-title">Top 5 high-cost search terms</div>
        <div style="position:relative;width:100%;height:210px"><canvas id="termChart"></canvas></div>
      </div>
    </div>

    <div class="insight-grid">
      <div class="insight">
        <div class="insight-text"><strong>CPC efficiency:</strong> Winning auctions at $2.24 vs $3.00 max signals a strong Quality Score. Google rewards ad relevance with lower prices — creating a 25% buffer to outbid high-intent searches like "luxury long-term RV park Bakersfield."</div>
      </div>
      <div class="insight">
        <div class="insight-text"><strong>Sweet-spot demographic:</strong> 60%+ of audience is aged 45–65+, confirming alignment with Extended Stay and Retiree profiles. Mobile-first setup with Click-to-Call tracking matches how this segment engages.</div>
      </div>
      <div class="insight">
        <div class="insight-text"><strong>Waste reduction applied:</strong> Shifted from Broad Match to Phrase Match. Negative keywords added: Tent, Beach, Free, Rental, Repair. Every dollar now targets Bakersfield-specific site/lot seekers.</div>
      </div>
      <div class="insight">
        <div class="insight-text"><strong>What to expect:</strong> Total clicks may dip slightly — this is intentional. CTR and lead quality will improve. Review the Conversions column in 7–10 days for first recorded phone leads.</div>
      </div>
    </div>

    <div class="action-box">
      <div class="action-title">Recent optimizations applied</div>
      <div class="action-items">
        <div class="action-item"><strong>Match type</strong>Switched Broad → Phrase Match for Bakersfield-specific targeting</div>
        <div class="action-item"><strong>Negative keywords</strong>Blocked: Tent, Beach, Free, Rental, Repair — eliminating junk traffic</div>
        <div class="action-item"><strong>Conversion tracking</strong>Website Call Tracking activated — phone leads now measurable</div>
      </div>
    </div>
  </div>

  <footer>Shaded Haven RV Park · Google Ads Campaign Report · March 4 – April 2, 2025</footer>

  <script src="https://cdnjs.cloudflare.com/ajax/libs/Chart.js/4.4.1/chart.umd.js"></script>
  <script>
    const isDark = matchMedia('(prefers-color-scheme: dark)').matches;
    const gridColor = isDark ? 'rgba(255,255,255,0.07)' : 'rgba(0,0,0,0.07)';
    const labelColor = isDark ? '#9a9993' : '#888';

    // Device donut
    const deviceData = {
      labels: ['Mobile phones', 'Computers', 'TV screens', 'Tablets'],
      data: [91.7, 5.2, 0.0, 3.1],
      colors: ['#378ADD', '#1D9E75', '#D4537E', '#BA7517']
    };
    new Chart(document.getElementById('deviceChart'), {
      type: 'doughnut',
      data: {
        labels: deviceData.labels,
        datasets: [{
          data: deviceData.data,
          backgroundColor: deviceData.colors,
          borderWidth: 2,
          borderColor: isDark ? '#1e1e1c' : '#fff',
          hoverOffset: 4
        }]
      },
      options: {
        responsive: true,
        maintainAspectRatio: false,
        cutout: '62%',
        plugins: {
          legend: { display: false },
          tooltip: { callbacks: { label: i => `${i.label}: ${i.raw}%` } }
        }
      }
    });

    const leg = document.getElementById('deviceLegend');
    deviceData.labels.forEach((l, i) => {
      const s = document.createElement('span');
      s.style.cssText = 'display:flex;align-items:center;';
      s.innerHTML = `<span class="legend-dot" style="background:${deviceData.colors[i]}"></span>${l} ${deviceData.data[i]}%`;
      leg.appendChild(s);
    });

    // Age bar chart
    new Chart(document.getElementById('ageChart'), {
      type: 'bar',
      data: {
        labels: ['18–24', '25–34', '35–44', '45–54', '55–64', '65+'],
        datasets: [{
          data: [68, 126, 138, 168, 182, 177],
          backgroundColor: ['#3C3489', '#534AB7', '#7F77DD', '#D85A30', '#993C1D', '#BA7517'],
          borderRadius: 4,
          borderSkipped: false
        }]
      },
      options: {
        responsive: true,
        maintainAspectRatio: false,
        plugins: {
          legend: { display: false },
          tooltip: { callbacks: { label: i => `${i.raw} impressions` } }
        },
        scales: {
          x: { grid: { color: gridColor }, ticks: { color: labelColor, font: { size: 11 } } },
          y: { grid: { color: gridColor }, ticks: { color: labelColor, font: { size: 11 } }, title: { display: true, text: 'Impressions', color: labelColor, font: { size: 10 } } }
        }
      }
    });

    // Hour line chart
    const hours = ['12a','1a','2a','3a','4a','5a','6a','7a','8a','9a','10a','11a','12p','1p','2p','3p','4p','5p','6p','7p','8p','9p','10p','11p'];
    const impressions = [0,0,0,0,0,0,0,0,41,84,117,135,159,138,141,91,31,4,2,0,0,0,0,0];
    new Chart(document.getElementById('hourChart'), {
      type: 'line',
      data: {
        labels: hours,
        datasets: [{
          data: impressions,
          fill: true,
          backgroundColor: isDark ? 'rgba(55,138,221,0.15)' : 'rgba(55,138,221,0.1)',
          borderColor: '#378ADD',
          borderWidth: 2,
          pointBackgroundColor: '#378ADD',
          pointRadius: 2,
          pointHoverRadius: 5,
          tension: 0.35
        }]
      },
      options: {
        responsive: true,
        maintainAspectRatio: false,
        plugins: {
          legend: { display: false },
          tooltip: { callbacks: { label: i => `${i.raw} impressions` } }
        },
        scales: {
          x: { grid: { color: gridColor }, ticks: { color: labelColor, font: { size: 9 }, maxRotation: 45, autoSkip: true, maxTicksLimit: 12 } },
          y: { grid: { color: gridColor }, ticks: { color: labelColor, font: { size: 11 } }, suggestedMax: 180 }
        }
      }
    });

    // Search terms horizontal bar
    new Chart(document.getElementById('termChart'), {
      type: 'bar',
      data: {
        labels: ['rv parks bakersfield', 'rv park', 'shaded haven rv park photos', 'buena vista lake camping', 'bakersfield rv park'],
        datasets: [{
          data: [11.4, 10.9, 6.8, 5.8, 5.1],
          backgroundColor: ['#26215C', '#534AB7', '#993C1D', '#D85A30', '#EF9F27'],
          borderRadius: 4,
          borderSkipped: false
        }]
      },
      options: {
        indexAxis: 'y',
        responsive: true,
        maintainAspectRatio: false,
        plugins: {
          legend: { display: false },
          tooltip: { callbacks: { label: i => `$${i.raw.toFixed(2)}` } }
        },
        scales: {
          x: { grid: { color: gridColor }, ticks: { color: labelColor, font: { size: 10 }, callback: v => `$${v}` } },
          y: { grid: { display: false }, ticks: { color: isDark ? '#ccc' : '#555', font: { size: 10 } } }
        }
      }
    });
  </script>
</body>
</html>
